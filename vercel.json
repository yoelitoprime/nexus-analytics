{
  "buildCommand": "npx vite build",
  "installCommand": "npm ci --no-audit --no-fund || npm install --no-audit --no-fund",
  "framework": "vite",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ]
}